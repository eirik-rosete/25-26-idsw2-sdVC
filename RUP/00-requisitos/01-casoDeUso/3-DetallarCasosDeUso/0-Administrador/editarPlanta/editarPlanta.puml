@startuml editarPlanta

skinparam linetype polyline

state in2 as "PLANTAS_ABIERTO"
in2 -[#green]-> editarPlanta

state editarPlanta as "editarPlanta()" {

    state " " as EditandoDatos
    state " " as GuardandoDatos 

    [*] -[#green]-> EditandoDatos 
    note on link
    <b>Administrador</b> solicita editar planta
    end note    
    
    EditandoDatos -[#green]-> GuardandoDatos
    note on link
    <b>Sistema</b> presenta datos de edición
    • Código, nombre de la planta
    • Región a la que pertenece (asignación jerárquica)
    • Espacios contenidos en la planta (lectura)
    • Descripción, nivel/piso
    
    <b>Sistema</b> permite solicitar:
    • modificar campos
    • guardar planta
    • cancelar edición
    end note
    
    GuardandoDatos -[#green]-> EditandoDatos
    note on link
    <b>Administrador</b> solicita modificar campos
    end note
    
    GuardandoDatos -[#green]-> [*]
    note on link
    <b>Administrador</b> solicita guardar y salir
    end note

    GuardandoDatos -[#red]-> [*]
    note on link
    <b>Administrador</b> solicita cancelar edición
    end note

}

editarPlanta -[#green]-> PLANTAS_ABIERTO
note on link
abrirListaPlantas()
end note

editarPlanta -[#red]-> PLANTAS_ABIERTO
note on link
cancelar edición
end note

@enduml
