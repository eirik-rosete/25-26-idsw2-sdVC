@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center

boundary "CrearEspacioView" as view <<boundary>> #629EF9
control "EspaciosController" as controller <<control>> #b5bd68
entity "EspacioRepository" as repo <<entity>> #F2AC4E
entity "Espacio" as model <<entity>> #F2AC4E

state ":Espacios Abierto" as state1 <<collaboration>> #CDEBA5
state ":Collaboration EditarEspacio" as edit <<collaboration>> #CDEBA5

state1 -> view : crearEspacio()
view -> controller : iniciarCreacion()
view -> controller : crearEspacio(datosMinimos)
controller -> repo : crear(datosMinimos) : Espacio
repo -> model : <<create>>
repo --> controller : nuevoEspacio
controller --> view : ok
view -> edit : <<include>> editarEspacio(nuevoEspacio)
@enduml
