@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center

boundary "EditarPlantaView" as view <<boundary>> #629EF9
control "PlantasController" as controller <<control>> #b5bd68
entity "PlantaRepository" as repo <<entity>> #F2AC4E
entity "Planta" as model <<entity>> #F2AC4E

state ":Plantas Abierto" as state1 <<collaboration>> #CDEBA5

state1 -> view : editarPlanta(id)
view -> controller : cargarDatos(id)
controller -> repo : obtenerPorId(id) : Planta
repo --> controller : planta
controller --> view : render()
view -> controller : guardarCambios(datos)
controller -> model : actualizar(datos)
controller -> repo : guardar(planta)
controller --> view : ok
view -> state1 : <<include>>
@enduml
