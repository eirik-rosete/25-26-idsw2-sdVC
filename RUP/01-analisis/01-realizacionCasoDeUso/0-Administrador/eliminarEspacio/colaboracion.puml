@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center

boundary "EliminarEspacioView" as view <<boundary>> #629EF9
control "EspaciosController" as controller <<control>> #b5bd68
entity "EspacioRepository" as repo <<entity>> #F2AC4E
entity "Espacio" as model <<entity>> #F2AC4E

state ":Espacios Abierto" as state1 <<collaboration>> #CDEBA5

state1 -> view : eliminarEspacio(id)
view -> controller : solicitarEliminacion(id)
controller -> repo : verificarDependencias(id)
repo --> controller : ok
controller --> view : pedirConfirmacion()
view -> controller : confirmarEliminacion(id)
controller -> repo : eliminar(id)
controller --> view : ok
view -> state1 : <<include>>
@enduml
